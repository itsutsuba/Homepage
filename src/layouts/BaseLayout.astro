---
import "../styles/global.css";
const { title = "うろ覚えオレンジ", description = "うろ覚えオレンジの音楽作品・活動情報をまとめたWebサイトです。" } = Astro.props;
const siteTitle = title === "うろ覚えオレンジ" ? title : `${title} | うろ覚えオレンジ`;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="brand" href={base}>
          <span class="brand-mark">UO</span>
          <span><strong>うろ覚えオレンジ</strong><small>Rock / Vocal Synth / Home Recording</small></span>
        </a>
        <nav class="site-nav" aria-label="メインナビゲーション">
          <a href={base}>Top</a><a href={`${base}music/`}>Music</a><a href={`${base}profile/`}>Profile</a><a href={`${base}works/`}>Works</a><a href={`${base}contact/`}>Contact</a>
        </nav>
      </header>
      <main><slot /></main>
      <footer class="site-footer"><small>© {new Date().getFullYear()} うろ覚えオレンジ</small></footer>
    </div>
  </body>
</html>
